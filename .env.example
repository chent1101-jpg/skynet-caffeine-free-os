# Copy to .env and fill in values

# Auth — password Tim uses to log in
HERMES_PASSWORD=change_me

# JWT signing secret — generate with: openssl rand -hex 32
JWT_SECRET=change_me_to_random_string

# n8n base URL (used for health check and workflow graph API)
N8N_BASE_URL=https://your-n8n-instance.example.com

# n8n webhook URL that returns { emails: [], events: [] }
N8N_BRIEFING_URL=https://your-n8n-instance.example.com/webhook/hermes-briefing

# n8n API key (for workflow graph panel)
N8N_API_KEY=

# Hermes OS public domain (used in docker-compose Traefik label)
HERMES_DOMAIN=your-hermes-domain.example.com

# Server port (3001 for local dev, 3000 in Docker)
PORT=3001

# Set to "production" in Docker
NODE_ENV=development
